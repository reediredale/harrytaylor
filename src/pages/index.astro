---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImg from '../gallery-content/20220927_125745.jpg';

const PHONE = '0421 441 520';
const PHONE_HREF = `tel:${PHONE.replace(/\s/g, '')}`;

const EMAIL = 'info@harrytaylorupholstery.com.au';

const ADDRESS = 'Wynnum, Brisbane, QLD 4178';

const services = [
  {
    icon: '🛋️',
    title: 'Sofa & Armchair Reupholstery',
    desc: 'Breathe new life into tired sofas and armchairs. We work with all frame types and a wide selection of quality fabrics.',
  },
  {
    icon: '🪑',
    title: 'Dining Chair Seats',
    desc: 'Quick turnaround on dining chair drop seats and full chair reupholstery — perfect for a refresh before any occasion.',
  },
  {
    icon: '🕰️',
    title: 'Mid Century Furniture',
    desc: 'Specialists in restoring and reupholstering mid century modern pieces — from Danish armchairs to retro lounges — honouring their original character.',
  },
  {
    icon: '🏺',
    title: 'Antique Restoration',
    desc: 'Sympathetic restoration of period furniture using traditional techniques and period-appropriate materials.',
  },
  {
    icon: '🛏️',
    title: 'Headboards & Ottomans',
    desc: 'Bespoke headboards made to measure, plus storage ottomans and bedroom seating upholstered to your specification.',
  },
  {
    icon: '⛵',
    title: 'Marine Upholstery',
    desc: 'Weatherproof cushions, berth mattresses and cockpit seating built to withstand the elements.',
  },
];

const rawImages = import.meta.glob<{ default: ImageMetadata }>(
  '../gallery-content/*.jpg',
  { eager: true }
);
const imageMap = Object.fromEntries(
  Object.entries(rawImages).map(([path, mod]) => [path.split('/').pop()!, mod.default])
);
// Ordered by visual impact — most striking work first
const galleryOrder = [
  '20220927_125745.jpg',  // teal botanical + hot pink piping
  '20240726_110551.jpg',  // mustard yellow sculptural row
  '20230808_133929.jpg',  // bold abstract-art fabric chairs
  '20231212_143507.jpg',  // sky blue + yellow mid-century sofa
  '20230323_134340.jpg',  // red native-print sofa with timber arms
  '1000044739.jpg',       // botanical print in boutique mirror
  '20241206_073737.jpg',  // emerald outdoor chairs on deck
  '20250526_133919.jpg',  // curved damask chaise
  '20240426_152954.jpg',  // teal Victorian tufted pair
  '20231004_141436.jpg',  // blue leather antique button-back
  '20230314_090729.jpg',  // raspberry wingbacks with print
  '20230329_130428.jpg',  // geometric retro armchairs
  '20240219_140353.jpg',  // chartreuse mid-century chair
  '20250829_092533.jpg',  // cream tufted antique pair
  '20230802_083209.jpg',  // forest-print wingbacks in home
  '20240301_084518.jpg',  // blue art deco with tropical detail
  '20230914_093631.jpg',  // blue tropical scroll armchairs
  '20231207_084940.jpg',  // Danish mid-century blue tufted
  '20221220_135932.jpg',  // orange chenille chairs + ottoman
  '20240913_073207.jpg',  // green Scandi lounge suite in home
  '20240815_131107.jpg',  // orange tufted pod/space-age chairs
  '20240131_135532.jpg',  // avocado green curved sectional
  '1000044735.jpg',       // marine curved banquette in boat
  '20230202_140435.jpg',  // teal botanical pair outside
  '1000044740.jpg',       // orange leather 3-piece suite
  '1000044741.jpg',       // botanical cantilever dining chairs
  '1000044742.jpg',       // commercial bar seating
  '20240119_130925.jpg',  // kitchen banquette with bolsters
  '20240417_144127.jpg',  // pool loungers
  '1000044744.jpg',       // commercial curved banquette
  '20241010_093601.jpg',  // low L-shaped sofa
  '1000044738.jpg',       // room with blue chairs
  '1000044737.jpg',       // dark moody bar seating
];
const galleryImages = galleryOrder.map((name) => imageMap[name]).filter(Boolean);
---

<Layout>
  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="#top" class="wordmark">
        <span class="wordmark-name">Harry Taylor</span>
        <span class="wordmark-sub">Upholstery</span>
      </a>

      <nav class="header-nav">
        <a href="#services">Services</a>
        <a href="#gallery">Gallery</a>
        <a href="#contact">Contact</a>
      </nav>

      <a
        class="btn-phone header-phone"
        href={PHONE_HREF}
        onclick="window.trackPhoneClick && window.trackPhoneClick()"
      >
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {PHONE}
      </a>
    </div>
  </header>

  <!-- ═══════════════════════════════ HERO ════════════════════════════════ -->
  <section id="top" class="hero">
    <Image
      src={heroImg}
      alt=""
      class="hero-bg"
      width={1600}
      format="webp"
      quality={80}
      loading="eager"
      aria-hidden="true"
    />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="section-label" style="color: var(--gold-light)">Established Craftsmen</span>
      <h1>Expert Upholstery,<br />Crafted to Last</h1>
      <p class="hero-sub">
        From cherished antiques to modern sofas, car interiors to marine cushions —
        we restore, repair and reupholster with traditional skill and an eye for detail.
      </p>
      <div class="hero-ctas">
        <a
          class="btn-phone hero-btn-phone"
          href={PHONE_HREF}
          onclick="window.trackPhoneClick && window.trackPhoneClick()"
        >
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call for a Free Quote — {PHONE}
        </a>
        <a href="#services" class="hero-btn-secondary">See Our Services</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ TRUST BAR ════════════════════════════ -->
  <div class="trust-bar">
    <div class="container trust-inner">
      <div class="trust-item">
        <strong>Est. 1959</strong>
        <span>over 65 years of craft</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <strong>Mid Century</strong>
        <span>specialists</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <strong>Free Quotes</strong>
        <span>no obligation</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <strong>Wynnum</strong>
        <span>Brisbane, QLD</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════ SERVICES ════════════════════════════ -->
  <section id="services" class="services-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What We Do</span>
        <h2 class="section-heading">A Full Range of<br />Upholstery Services</h2>
        <p class="section-intro">
          Whether it's a much-loved armchair or a set of marine cushions, every job receives
          the same care and craftsmanship.
        </p>
      </div>

      <div class="services-grid">
        {services.map((s) => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="services-cta">
        <p>Not sure if we cover your job? Give us a ring — we're always happy to chat.</p>
        <a
          class="btn-phone"
          href={PHONE_HREF}
          onclick="window.trackPhoneClick && window.trackPhoneClick()"
        >
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {PHONE}
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ GALLERY ══════════════════════════════ -->
  <section id="gallery" class="gallery-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Our Work</span>
        <h2 class="section-heading">See the Difference</h2>
        <p class="section-intro">
          Every piece tells a story. Here's a selection of recent projects.
        </p>
      </div>

      <div class="gallery-grid">
        {galleryImages.map((img, i) => (
          <div class="gallery-item">
            <Image
              src={img}
              alt="Upholstery work by Harry Taylor"
              width={900}
              format="webp"
              quality={82}
              loading={i < 8 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ CONTACT ══════════════════════════════ -->
  <section id="contact" class="contact-section">
    <div class="container contact-inner">
      <div class="contact-text">
        <span class="section-label">Get In Touch</span>
        <h2 class="section-heading">Ready to Get Started?</h2>
        <p class="section-intro" style="margin-bottom: 2rem;">
          The fastest way to get a quote is to give us a call. We'll talk through your project,
          arrange a visit if needed, and give you a no-obligation price.
        </p>

        <div class="contact-details">
          <a
            class="contact-phone"
            href={PHONE_HREF}
            onclick="window.trackPhoneClick && window.trackPhoneClick()"
          >
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <span class="contact-detail-label">Phone</span>
              <span class="contact-detail-value phone-number">{PHONE}</span>
            </div>
          </a>

          <a class="contact-detail-row" href={`mailto:${EMAIL}`}>
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div>
              <span class="contact-detail-label">Email</span>
              <span class="contact-detail-value">{EMAIL}</span>
            </div>
          </a>

          <div class="contact-detail-row">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <span class="contact-detail-label">Location</span>
              <span class="contact-detail-value">{ADDRESS}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-cta-box">
        <p class="cta-box-heading">Get Your Free Quote</p>
        <p class="cta-box-sub">
          Calls are answered Mon–Fri 8am–6pm.<br />
          Leave a message and we'll call you back.
        </p>
        <a
          class="btn-phone cta-box-phone"
          href={PHONE_HREF}
          onclick="window.trackPhoneClick && window.trackPhoneClick()"
        >
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {PHONE}
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ FOOTER ═══════════════════════════════ -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <p class="footer-brand">Harry Taylor Upholstery</p>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Harry Taylor Upholstery. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  /* ── HEADER ─────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(17, 17, 17, 0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(184, 150, 62, 0.2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 68px;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    flex-shrink: 0;
  }
  .wordmark-name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: #fff;
    letter-spacing: 0.02em;
  }
  .wordmark-sub {
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .header-nav {
    display: flex;
    gap: 1.75rem;
    margin-left: auto;
  }
  .header-nav a {
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .header-nav a:hover { color: #fff; }

  .header-phone { font-size: 0.9rem; padding: 10px 20px; flex-shrink: 0; }

  @media (max-width: 700px) {
    .header-nav { display: none; }
    .header-phone { margin-left: auto; }
  }

  /* ── HERO ────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: clamp(520px, 80vh, 800px);
    display: flex;
    align-items: center;
    background: var(--dark);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.38;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.70) 55%, rgba(10,10,10,0.45) 100%),
      linear-gradient(to top,   rgba(10,10,10,0.6)  0%, transparent 40%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 40px;
    padding-bottom: 40px;
    max-width: 680px;
  }

  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    font-weight: normal;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.72);
    max-width: 520px;
    margin-bottom: 2.25rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .hero-btn-phone { font-size: 1.05rem; padding: 16px 30px; }

  .hero-btn-secondary {
    color: rgba(255,255,255,0.8);
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(255,255,255,0.35);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .hero-btn-secondary:hover { color: #fff; border-color: rgba(255,255,255,0.7); }

  /* ── TRUST BAR ───────────────────────────────────────── */
  .trust-bar {
    background: var(--charcoal);
    padding: 28px 0;
  }

  .trust-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 36px;
    gap: 2px;
  }
  .trust-item strong {
    font-size: 1.1rem;
    color: var(--gold-light);
    font-weight: 700;
  }
  .trust-item span {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.04em;
  }

  .trust-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.12);
  }

  @media (max-width: 600px) {
    .trust-divider { display: none; }
    .trust-item { padding: 6px 20px; }
  }

  /* ── SERVICES ────────────────────────────────────────── */
  .services-section { background: var(--warm-white); }

  .section-header { margin-bottom: 3rem; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .service-card {
    background: #fff;
    border: 1px solid var(--light-grey);
    border-radius: 8px;
    padding: 2rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .service-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .service-card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: normal;
    color: var(--charcoal);
    margin-bottom: 0.6rem;
  }

  .service-card p {
    font-size: 0.93rem;
    color: var(--mid-grey);
    line-height: 1.65;
  }

  .services-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 2.5rem;
    background: var(--cream);
    border-radius: 8px;
    border-left: 4px solid var(--gold);
  }
  .services-cta p {
    flex: 1;
    min-width: 200px;
    font-size: 1rem;
    color: var(--mid-grey);
  }

  /* ── GALLERY ─────────────────────────────────────────── */
  .gallery-section { background: var(--cream); }

  .gallery-grid {
    columns: 4;
    column-gap: 10px;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 10px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--light-grey);
    position: relative;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }
  .gallery-item:hover img { transform: scale(1.03); }

  @media (max-width: 900px) { .gallery-grid { columns: 3; } }
  @media (max-width: 600px) { .gallery-grid { columns: 2; } }

  /* ── CONTACT ─────────────────────────────────────────── */
  .contact-section { background: var(--charcoal); color: #fff; }
  .contact-section .section-label { color: var(--gold-light); }
  .contact-section .section-heading { color: #fff; }
  .contact-section .section-intro { color: rgba(255,255,255,0.65); }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .contact-details { display: flex; flex-direction: column; gap: 1.25rem; }

  .contact-detail-row,
  .contact-phone {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: rgba(255,255,255,0.8);
    transition: color 0.2s;
  }
  .contact-phone:hover { color: var(--gold-light); }

  .contact-phone svg { flex-shrink: 0; color: var(--gold); }
  .contact-detail-row svg { flex-shrink: 0; color: rgba(255,255,255,0.4); }

  .contact-detail-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2px;
  }
  .contact-detail-value {
    display: block;
    font-size: 1rem;
    font-weight: 500;
  }

  .phone-number { font-size: 1.35rem; font-weight: 700; }

  /* CTA box */
  .contact-cta-box {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(184,150,62,0.3);
    border-radius: 10px;
    padding: 2.5rem;
    text-align: center;
  }

  .cta-box-heading {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cta-box-sub {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .cta-box-phone {
    display: inline-flex;
    font-size: 1.1rem;
    padding: 16px 32px;
    width: 100%;
    justify-content: center;
  }

  /* ── FOOTER ──────────────────────────────────────────── */
  .site-footer {
    background: var(--dark);
    padding: 24px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    display: flex;
